#include <iostream>
using namespace std;

int main() {
    float num1, num2;
    char op;
   
    cout<<"Enter your number 1: " ;
    cin>>num1;
    cout<<" Enter operator (+,-,*,/): ";
    cin>>op;
    cout<<"Enter your number 2: ";
    cin>>num2;
   
    if (op == '+')
        cout<<"Result: " << num1 + num2;
    else if (op == '-')
        cout<<"Result: " << num1 - num2;
    else if (op == '*')
        cout<<"Result: " << num1 * num2;
    else if (op == '/')
        cout<<"Result: " << num1 / num2;
    else
        cout<<"Invalid result";
       
return 0;
}
